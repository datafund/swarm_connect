# === Swarm Bee Node ===
# URL to the Swarm Bee node API (required)
SWARM_BEE_API_URL=https://api.gateway.ethswarm.org
# API_KEY=
# API_KEY_NAME=X-API-Key

# === Server Settings ===
# HOST=127.0.0.1                              # Server bind address (default: 127.0.0.1)
# PORT=8000                                   # Server port (default: 8000)
# RELOAD=true                                 # Enable auto-reload for development (default: true)
# SSL_KEYFILE=./localhost+2-key.pem           # Path to SSL key file (for HTTPS dev)
# SSL_CERTFILE=./localhost+2.pem              # Path to SSL certificate file (for HTTPS dev)

# === Stamp Propagation Timing ===
# Expected propagation delay (in seconds) after purchasing a new stamp.
# Used to calculate propagation timing signals (propagationStatus, estimatedReadyAt).
# STAMP_PROPAGATION_SECONDS=120

# === Upload Limits ===
# Maximum file upload size in megabytes (default: 10)
# MAX_UPLOAD_SIZE_MB=10

# === Global Rate Limiting ===
# Per-IP rate limiting for all endpoints (skipped when x402 is enabled).
# RATE_LIMIT_ENABLED=true                     # Master switch (default: true)
# RATE_LIMIT_PER_MINUTE=60                    # Requests per minute per IP (default: 60)
# RATE_LIMIT_BURST=10                         # Extra burst capacity (default: 10)

# === CORS Settings ===
# Controls which origins can make cross-origin requests to this gateway.
# Default is "*" (all origins) for development convenience.
#
# IMPORTANT: In production, restrict to specific origins to prevent
# unauthorized cross-origin access to your gateway.
#
# CORS_ALLOWED_ORIGINS=*                           # "*" for all origins (development only)
# CORS_ALLOW_CREDENTIALS=false                     # Must be false when using "*" origins
#
# Production example — restrict to known frontend origins:
# CORS_ALLOWED_ORIGINS=https://app.datafund.io,https://fairdrop.datafund.io,https://verity.datafund.io
# CORS_ALLOW_CREDENTIALS=true
#
# When deploying publicly, always set CORS_ALLOWED_ORIGINS to specific
# domains rather than "*". Using "*" allows any website to make requests
# to your gateway from a user's browser.

# === x402 Payment Integration (Optional) ===
# Pay-per-request access using the x402 protocol. When enabled, clients pay
# in USDC on Base chain to access upload endpoints. Downloads remain free.
# See docs/x402-operator-guide.md for full documentation.
#
# X402_ENABLED=false                          # Master switch (default: false)
# X402_PAY_TO_ADDRESS=                        # USDC receiving wallet address (Base chain)
# X402_NETWORK=base-sepolia                   # Network: "base-sepolia" (testnet) or "base" (mainnet)
# X402_FACILITATOR_URL=https://x402.org/facilitator  # Payment verification service
#
# Free tier: allow non-paying users with stricter rate limits
# X402_FREE_TIER_ENABLED=true                 # Allow free access with rate limits (default: true)
# X402_FREE_TIER_RATE_LIMIT=3                 # Requests per minute for free tier (default: 3)
#
# Pricing: controls how BZZ costs are converted to USDC prices
# X402_BZZ_USD_RATE=0.50                      # Manual BZZ/USD rate (default: $0.50)
# X402_MARKUP_PERCENT=50.0                    # Markup percentage on cost (default: 50%)
# X402_MIN_PRICE_USD=0.01                     # Minimum charge per request in USD (default: $0.01)
# X402_MAX_STAMP_BZZ=5.0                      # Max single stamp purchase in BZZ (default: 5.0)
# X402_RATE_LIMIT_PER_IP=10                   # Requests per minute for paying users (default: 10)
#
# Access control: IP-based allow/block lists
# X402_BLACKLIST_IPS=                          # Comma-separated blocked IPs
# X402_WHITELIST_IPS=                          # Comma-separated free-access IPs (bypass payment)
#
# Wallet monitoring thresholds (warnings in /health endpoint)
# X402_XBZZ_WARN_THRESHOLD=10.0              # Warn if Bee node xBZZ balance below (default: 10)
# X402_XDAI_WARN_THRESHOLD=0.5               # Warn if Bee node xDAI balance below (default: 0.5)
# X402_CHEQUEBOOK_WARN_THRESHOLD=5.0          # Warn if chequebook balance below (default: 5.0)
# X402_BASE_ETH_WARN_THRESHOLD=0.005          # Warn if Base wallet ETH below (default: 0.005)
# X402_BASE_ETH_CRITICAL_THRESHOLD=0.001      # Block if Base wallet ETH below (default: 0.001)
#
# Base chain RPC for monitoring USDC receipts
# BASE_RPC_URL=https://sepolia.base.org       # Base Sepolia (testnet) or https://mainnet.base.org
#
# Audit logging
# X402_AUDIT_LOG_PATH=logs/x402_audit.jsonl   # Transaction audit log file (default: logs/x402_audit.jsonl)

# === Stamp Pool (Optional) ===
# Pre-purchased stamp reserve for instant acquisition (<5 sec vs >1 min).
# When enabled, the gateway maintains a pool of ready-to-use stamps.
# See docs/stamp-pool-guide.md for full documentation.
#
# STAMP_POOL_ENABLED=false                    # Master switch (default: false)
# STAMP_POOL_RESERVE_SMALL=1                  # Depth-17 stamps to keep in reserve
# STAMP_POOL_RESERVE_MEDIUM=1                 # Depth-20 stamps to keep in reserve
# STAMP_POOL_RESERVE_LARGE=0                  # Depth-22 stamps to keep in reserve
# STAMP_POOL_CHECK_INTERVAL_SECONDS=900       # Check pool every N seconds (default: 15 min)
# STAMP_POOL_MIN_TTL_HOURS=24                 # Top up if TTL below this (hours)
# STAMP_POOL_TOPUP_HOURS=168                  # How much TTL to add when topping up (1 week)
# STAMP_POOL_LOW_RESERVE_THRESHOLD=1          # Alert when reserve drops to this level
# STAMP_POOL_DEFAULT_DURATION_HOURS=168       # Duration for newly purchased pool stamps (1 week)
# STAMP_POOL_IMMEDIATE_REPLENISH=true         # Purchase replacement immediately on release (default: true)
# STAMP_POOL_STATE_FILE=data/pool_state.json  # State file for pool persistence across restarts
# STAMP_OWNERSHIP_FILE=data/stamp_owners.json # Stamp ownership tracking for x402 enforcement
#
# Note: Pool will auto-purchase stamps when reserve is low.
# Ensure Bee node wallet has sufficient xBZZ and xDAI.

# === Notary/Provenance Signing (Optional) ===
# Gateway notary signing for document provenance.
# See docs/notary-guide.md for full documentation.
#
# NOTARY_ENABLED=false                          # Master switch (default: false)
# NOTARY_PRIVATE_KEY=                           # Hex private key (without 0x prefix)
#
# To generate a new key:
#   python scripts/generate_notary_key.py
#
# Security: Keep NOTARY_PRIVATE_KEY secret. Anyone with this key can sign as your notary.
