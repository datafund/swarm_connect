SWARM_BEE_API_URL=https://api.gateway.ethswarm.org
# API_KEY=
# API_KEY_NAME=X-API-Key

# === Upload Limits ===
# Maximum file upload size in megabytes (default: 10)
# MAX_UPLOAD_SIZE_MB=10

# === Global Rate Limiting ===
# Per-IP rate limiting for all endpoints (skipped when x402 is enabled).
# RATE_LIMIT_ENABLED=true                     # Master switch (default: true)
# RATE_LIMIT_PER_MINUTE=60                    # Requests per minute per IP (default: 60)
# RATE_LIMIT_BURST=10                         # Extra burst capacity (default: 10)

# === CORS Settings ===
# Controls which origins can make cross-origin requests to this gateway.
# Default is "*" (all origins) for development convenience.
#
# IMPORTANT: In production, restrict to specific origins to prevent
# unauthorized cross-origin access to your gateway.
#
# CORS_ALLOWED_ORIGINS=*                           # "*" for all origins (development only)
# CORS_ALLOW_CREDENTIALS=false                     # Must be false when using "*" origins
#
# Production example — restrict to known frontend origins:
# CORS_ALLOWED_ORIGINS=https://app.datafund.io,https://fairdrop.datafund.io,https://verity.datafund.io
# CORS_ALLOW_CREDENTIALS=true
#
# When deploying publicly, always set CORS_ALLOWED_ORIGINS to specific
# domains rather than "*". Using "*" allows any website to make requests
# to your gateway from a user's browser.

# === Stamp Pool (Optional) ===
# Pre-purchased stamp reserve for instant acquisition (<5 sec vs >1 min)
# See docs/stamp-pool-guide.md for full documentation
#
# STAMP_POOL_ENABLED=false                    # Master switch (default: false)
# STAMP_POOL_RESERVE_SMALL=1                  # Depth-17 stamps to keep in reserve
# STAMP_POOL_RESERVE_MEDIUM=1                 # Depth-20 stamps to keep in reserve
# STAMP_POOL_RESERVE_LARGE=0                  # Depth-22 stamps to keep in reserve
# STAMP_POOL_CHECK_INTERVAL_SECONDS=900       # Check pool every N seconds (default: 15 min)
# STAMP_POOL_MIN_TTL_HOURS=24                 # Top up if TTL below this (hours)
# STAMP_POOL_TOPUP_HOURS=168                  # How much TTL to add when topping up (1 week)
# STAMP_POOL_LOW_RESERVE_THRESHOLD=1          # Alert when reserve drops to this level
# STAMP_POOL_DEFAULT_DURATION_HOURS=168       # Duration for newly purchased pool stamps (1 week)
# STAMP_POOL_STATE_FILE=data/pool_state.json  # State file for pool persistence across restarts
# STAMP_OWNERSHIP_FILE=data/stamp_owners.json # Stamp ownership tracking for x402 enforcement
#
# Note: Pool will auto-purchase stamps when reserve is low.
# Ensure Bee node wallet has sufficient xBZZ and xDAI.

# === Notary/Provenance Signing (Optional) ===
# Gateway notary signing for document provenance
# See docs/notary-guide.md for full documentation
#
# NOTARY_ENABLED=false                          # Master switch (default: false)
# NOTARY_PRIVATE_KEY=                           # Hex private key (without 0x prefix)
#
# To generate a new key:
#   python scripts/generate_notary_key.py
#
# Security: Keep NOTARY_PRIVATE_KEY secret. Anyone with this key can sign as your notary.
